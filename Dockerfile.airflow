FROM apache/airflow:2.9.1

USER root
RUN apt-get update && apt-get install -y git libpq-dev && apt-get clean

USER airflow
RUN python -m venv /home/airflow/dbt-env && \
    /home/airflow/dbt-env/bin/pip install --no-cache-dir --upgrade pip && \
    /home/airflow/dbt-env/bin/pip install --no-cache-dir \
    "dbt-postgres==1.8.0"